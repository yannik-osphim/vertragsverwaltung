# Local application
APP_ENV=development
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/contracts
POSTGRES_MAINTENANCE_DB=postgres
DB_CONNECT_TIMEOUT_SECONDS=5
DB_LOCK_TIMEOUT_MS=5000
DB_STATEMENT_TIMEOUT_MS=60000
CONTRACT_DATA_DIR=data
SESSION_SECRET=change-me-before-production
SESSION_MAX_AGE_SECONDS=28800
SECURE_COOKIES=0
FORCE_HTTPS=0
ENABLE_SECURITY_HEADERS=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Reverse proxy
PUBLIC_SITE_ADDRESS=:8000
PROXY_HTTP_PORT=8000
PROXY_BIND_IP=0.0.0.0
MAX_UPLOAD_SIZE=50MB

# Initial admin user
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-first-start

# Optional sample data; keep disabled for normal starts.
ENABLE_SAMPLE_DATA=0

# Docker Compose Postgres
POSTGRES_DB=contracts
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_HOST_PORT=5433
DOCKER_DATABASE_URL=postgresql+psycopg://user:password@postgres:5432/contracts

# Docker Compose backups
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=14
